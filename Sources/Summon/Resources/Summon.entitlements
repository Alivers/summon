<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Sandbox is OFF — required for:
        - Registering global hotkeys via Carbon Event API
        - Spawning arbitrary terminal processes (claude, lazygit, k9s …)
        - Reading arbitrary working directories
    -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
